<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".Cm.MainActivity">



    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_height="wrap_content">


        <ImageView
            android:id="@+id/bookview_imageback"
            android:layout_width="wrap_content"
            android:layout_marginLeft="30dp"
            android:src="@drawable/arrow_back"
            android:layout_height="40dp">

        </ImageView>

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:layout_marginLeft="25dp"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:textStyle="bold"
                android:textSize="17sp"
                android:visibility="gone"
                android:layout_weight="1"
                android:text="সায়েন্স ফিকশন"
                android:layout_height="wrap_content">

            </TextView>


            <TextView
                android:layout_width="wrap_content"
                android:textSize="12sp"
                android:layout_weight="1"
                android:visibility="gone"
                android:text="মোট কনটেন্ট ১২৩ টি"
                android:layout_height="wrap_content">

            </TextView>


        </LinearLayout>




        <ImageView
            android:layout_width="wrap_content"
            android:layout_marginRight="20dp"
            android:src="@drawable/notification"
            android:layout_height="wrap_content">


        </ImageView>

    </LinearLayout>


    <EditText
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_marginRight="20dp"
        android:paddingRight="10dp"
        android:hint="মোট কনটেন্ট ১২৩ টি  "
        android:textColorHint="#3F3939"
        android:paddingLeft="20dp"
        android:textSize="15sp"
        android:background="@drawable/cardview_background"
        android:drawableRight="@drawable/baseline_search_24"
        android:layout_marginLeft="20dp"
        android:layout_height="50dp">

    </EditText>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <LinearLayout
            android:id="@+id/bookview_layout1"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginRight="20dp"
            android:layout_marginLeft="20dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:cardCornerRadius="10dp">


            <LinearLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginLeft="20dp"
                android:gravity="center"
                android:backgroundTint="@color/bookview_color1"
                android:background="@drawable/card_imageview_background"
                app:cardCornerRadius="10dp">


                <TextView
                    android:layout_width="wrap_content"
                    android:text="1"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/white"
                    android:layout_height="wrap_content">

                </TextView>


            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:text="meeting"
                    android:textAllCaps="true">


                </TextView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="serif"
                    android:layout_marginTop="5dp"
                    android:text="112 Items"
                    />



            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">



                <LinearLayout
                    android:layout_marginRight="20dp"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginLeft="20dp"
                    android:gravity="center"
                    app:cardCornerRadius="10dp">


                    <ImageView
                        android:layout_width="wrap_content"
                        android:text="1"
                        android:src="@drawable/icon29"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/white"
                        android:layout_height="wrap_content">

                    </ImageView>


                </LinearLayout>



            </LinearLayout>


        </LinearLayout>



        <LinearLayout
            style="@style/ShapeAppearance.Material3.Corner.ExtraLarge"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:background="@drawable/cardview_background"
            android:gravity="center"
            android:orientation="horizontal"
            app:cardCornerRadius="10dp">


            <LinearLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginLeft="20dp"
                android:gravity="center"
                android:background="@drawable/card_imageview_background"
                app:cardCornerRadius="10dp">


                <TextView
                    android:layout_width="wrap_content"
                    android:text="1"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/white"
                    android:layout_height="wrap_content">

                </TextView>


            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:text="oneir radio app desigin"
                    android:textAllCaps="true">


                </TextView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="serif"
                    android:layout_marginTop="5dp"
                    android:text="89 Items"
                    />


            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">



                <LinearLayout
                    android:layout_marginRight="20dp"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginLeft="20dp"
                    android:gravity="center"
                    app:cardCornerRadius="10dp">


                    <ImageView
                        android:layout_width="wrap_content"
                        android:text="1"
                        android:src="@drawable/icon29"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/white"
                        android:layout_height="wrap_content">

                    </ImageView>


                </LinearLayout>

            </LinearLayout>


        </LinearLayout>



    </LinearLayout>


</LinearLayout>