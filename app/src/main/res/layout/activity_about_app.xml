<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="@color/color_primary_dark"
    android:layout_height="match_parent"
    tools:context=".AboutApp">


    <LinearLayout
        android:background="@color/color_primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        >


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            >


            <ImageView
                android:id="@+id/sample_back_button"
                android:layout_marginStart="10dp"
                android:layout_width="26dp"
                android:layout_height="match_parent"
                android:src="@drawable/arrow_back"
                android:contentDescription="@string/todo" />


        </LinearLayout>



        <LinearLayout
            android:layout_marginStart="30dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <TextView
                android:layout_marginTop="3dp"
                android:id="@+id/sample_titel_textview_id"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="About"
                android:textStyle="bold"
                android:textSize="19sp"
                android:textColor="@color/title_text_color"
                android:gravity="center"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="right"
            android:orientation="horizontal"
            tools:ignore="RtlHardcoded">




            <ImageView
                android:id="@+id/sample_share"
                android:layout_marginEnd="20dp"
                android:layout_width="wrap_content"
                android:visibility="gone"
                android:layout_height="match_parent"
                android:src="@drawable/share"
                android:contentDescription="@string/todo" />

            <ImageView
                android:id="@+id/sample_setting"
                android:layout_marginEnd="13dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/settings_share"
                android:contentDescription="@string/todo" />


        </LinearLayout>


    </LinearLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="12dp"
                android:padding="20dp"
                android:background="@drawable/about_linear_background"
                >

                <LinearLayout
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@mipmap/ic_launcher_round"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="জাফর ইকবাল সমগ্র"
                            android:textColor="@color/title_text_color"
                            android:fontFamily="@font/solaimanlipi"
                            android:textSize="21sp"
                            android:textStyle="bold">

                        </TextView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_color"
                            android:text=" @aryan_arafat"
                            android:textSize="12sp"
                            android:textStyle="">

                        </TextView>


                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/info"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif-monospace"
                            android:text="Version"
                            android:textColor="@color/title_text_color"
                            android:textSize="17sp"
                            >

                        </TextView>

                        <TextView
                            android:id="@+id/about_version"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif-monospace"
                            android:textColor="@color/text_color"
                            android:text="2.7"
                            android:textSize="12sp"
                            android:textStyle="">

                        </TextView>


                    </LinearLayout>


                </LinearLayout>


                <LinearLayout
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/published_with_changes"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Changelog"
                            android:textColor="@color/title_text_color"
                            android:textSize="15sp"
                            >

                        </TextView>



                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/title_text_color"
                            android:textSize="15sp"
                            >

                        </TextView>



                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="20dp"
                android:background="@drawable/about_linear_background"
                >

                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:textColor="@color/title_text_color"
                        android:text="Author"
                        android:textSize="19sp"
                        android:textStyle="bold">

                    </TextView>





                </LinearLayout>

                <LinearLayout
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/person"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:fontFamily="serif"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aryan Arafat"
                            android:textColor="@color/title_text_color"
                            android:textSize="17sp"
                            >
                        </TextView>

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Banglasesh"
                            android:textColor="@color/text_color"
                            android:textSize="12sp"
                            >

                        </TextView>


                    </LinearLayout>


                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/person"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:fontFamily="serif"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mithun Sarker"
                            android:textColor="@color/title_text_color"
                            android:textSize="17sp"
                            >
                        </TextView>

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Banglasesh"
                            android:layout_marginBottom="10dp"
                            android:textColor="@color/text_color"
                            android:textSize="12sp"
                            >

                        </TextView>


                    </LinearLayout>


                </LinearLayout>


                <LinearLayout
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="24dp"
                        android:src="@drawable/download"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="download_from_cloud"
                            android:textColor="@color/title_text_color"
                            android:textSize="15sp"
                            >

                        </TextView>



                    </LinearLayout>


                </LinearLayout>



            </LinearLayout>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="12dp"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:background="@drawable/about_linear_background"
                >

                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:textColor="@color/title_text_color"
                        android:text="Company"
                        android:textSize="19sp"
                        android:textStyle="bold">

                    </TextView>





                </LinearLayout>

                <LinearLayout
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/house"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ario Inc."
                            android:textColor="@color/title_text_color"
                            android:textSize="17sp"
                            >
                        </TextView>

                        <TextView
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Android App Spacialist"
                            android:textColor="@color/text_color"
                            android:textSize="12sp"
                            >

                        </TextView>


                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    >

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/location"
                        android:contentDescription="@string/todo">

                    </ImageView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="27dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">


                        <TextView
                            android:paddingEnd="10dp"
                            android:fontFamily="serif-monospace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dhaka Bangladesh"
                            android:textColor="@color/title_text_color"
                            android:textSize="16sp"
                            tools:ignore="RtlSymmetry">

                        </TextView>


                    </LinearLayout>


                </LinearLayout>




            </LinearLayout>







        </LinearLayout>
    </ScrollView>




</LinearLayout>