<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Apps" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/color_primary</item>
        <!-- Customize your theme here. -->
        <item name="windowActionBar">false</item>
        <item name="android:navigationBarColor">@color/color_primary</item>

        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

    </style>

    <style name="Theme.Apps.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Apps.AppBarOverlay"
        parent="ThemeOverlay.AppCompat.Dark.ActionBar"
        >

    </style>

    <style name="Theme.Apps.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />



    <style
        name="BottomNavigationStyle" parent="Widget.Design.BottomNavigationView">
        <!--
            <item name="android:foreground">@drawable/ripple_custom</item>-->
        <!--<item name="itemBackground">@drawable/ripple_custom</item>-->
        <item name="itemIconTint">@color/bottom_navigation_color</item>
        <item name="itemTextColor">@color/bottom_navigation_color</item>
        <item name="backgroundColor">@color/google_color_primary</item>

        <!--        <item name="android:fontFamily">@font/varela_round</item>-->

    </style>


    <style name="tint">
       <item name="android:tint">@color/black</item>
    </style>

    <style name="BottomSheetDialog" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/bottomSheetStyleWrapper</item>
    </style>

    <style name="bottomSheetStyleWrapper" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>


</resources>